# ──────────────────────────────────────────────────────────────
# aahhWindows Backend — Environment Variables
# Copy to .env and fill in your actual values
# NEVER commit .env to version control
# ──────────────────────────────────────────────────────────────

PORT=3001

# ── PayU ──────────────────────────────────────────────────────
# Get from: PayU Dashboard -> Settings -> Merchant Keys
PAYU_MERCHANT_KEY=YOUR_MERCHANT_KEY
PAYU_MERCHANT_SALT=YOUR_MERCHANT_SALT

# ── Resend (email) ────────────────────────────────────────────
# Get from: https://resend.com/api-keys (free = 3,000 emails/month)
RESEND_API_KEY=your_resend_key_here

# ── Product ───────────────────────────────────────────────────
DOWNLOAD_URL=https://example.com/aahhwindows-setup.exe

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
